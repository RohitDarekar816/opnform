#!/bin/bash
set -e

main() {
    local COMMAND_AS_STRING="$*"
    local ROLE="api"

    case "$COMMAND_AS_STRING" in
        *"queue:work"*)
            ROLE="worker"
            ;;
        *"schedule:work"*)
            ROLE="scheduler"
            ;;
        *)
            ROLE="api"
            ;;
    esac

    echo "[Entrypoint] Role: $ROLE"

    prep_file_permissions
    prep_storage
    wait_for_db

    if [ "$ROLE" = "api" ]; then
        echo "[Entrypoint] Running API setup..."
        apply_db_migrations
        initialize_instance
        optimize_application
        exec "$@"
    elif [ "$ROLE" = "scheduler" ]; then
        echo "[Entrypoint] Running Scheduler setup..."
        php ./artisan app:scheduler-status --mode=record
        exec "$@"
    elif [ "$ROLE" = "worker" ]; then
        echo "[Entrypoint] Running Worker setup..."
        exec "$@"
    else
        echo "[Entrypoint] Error: Unknown role '$ROLE'"
        exit 1
    fi
}

prep_file_permissions() {
    chmod a+x ./artisan 2>/dev/null || true
}

prep_storage() {
    local app_storage_path="/usr/share/nginx/html/storage"

    mkdir -p "$app_storage_path/app/public"
    mkdir -p "$app_storage_path/framework/cache/data"
    mkdir -p "$app_storage_path/framework/sessions"
    mkdir -p "$app_storage_path/framework/views"
    mkdir -p "$app_storage_path/logs"

    chmod -R 775 "$app_storage_path" 2>/dev/null || true

    echo "[Entrypoint] Creating storage symlink"
    php ./artisan storage:link 2>/dev/null || true
}

wait_for_db() {
    echo "[Entrypoint] Waiting for database..."
    local max_attempts=60
    local attempt=1
    
    while [ $attempt -le $max_attempts ]; do
        if php ./artisan migrate:status 2>&1 | grep -q -E "(Migration table not found|Migration name|Connected)"; then
            echo "[Entrypoint] Database is ready"
            return 0
        fi
        echo "[Entrypoint] Waiting for database... ($attempt/$max_attempts)"
        sleep 2
        attempt=$((attempt + 1))
    done
    
    echo "[Entrypoint] Warning: Database may not be ready"
}

apply_db_migrations() {
    echo "[Entrypoint] Running migrations..."
    php ./artisan migrate --force || true
}

initialize_instance() {
    echo "[Entrypoint] Initializing telemetry..."
    php ./artisan telemetry:initialize-instance 2>/dev/null || true
}

optimize_application() {
    echo "[Entrypoint] Optimizing application..."
    php ./artisan optimize:clear 2>/dev/null || true
    php ./artisan optimize 2>/dev/null || true
}

main "$@"
