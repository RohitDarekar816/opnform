# Git
/.git
/.gitignore
/.gitattributes

# Dockerfiles and compose files (not needed in build context)
Dockerfile*
docker-compose*

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment files (keep template)
.env
.env.*
!.env.docker
!.env.example
!.env.production.example

# Documentation
*.md
docs/
LICENSE
SECURITY.md

# CI/CD
.github/
.workflows/

# Scripts
scripts/

# Amplify
amplify.yml

# Cursor rules
.cursor/

# API ignores
api/vendor/
api/node_modules/
api/storage/framework/
api/storage/logs/
api/storage/app/
api/.env
api/.env.*
api/*.log
api/_ide_helper_models.php
api/bootstrap/cache/*
api/phpunit.xml
api/phpstan.neon
api/pint.json
api/tests/

# Client ignores
client/node_modules/
client/.nuxt/
client/dist/
client/.output/
client/coverage/
client/.env
client/.env.*
client/npm-debug.log*
client/yarn-debug.log*
client/yarn-error.log*
client/test/
client/*.log
client/.eslintcache
client/vitest.config.ts

# Global ignores
**/*.log
**/.git/
**/node_modules/
**/.DS_Store
**/Thumbs.db
